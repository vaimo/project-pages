# Copy this file to .env.local and fill in all values.
# Never commit .env.local to source control.

# ── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token with `repo` (read) scope for the docs repository
GITHUB_TOKEN=

# Secret shared with the GitHub webhook (used to validate X-Hub-Signature-256)
GITHUB_WEBHOOK_SECRET=

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full URL of this deployment (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Vercel ───────────────────────────────────────────────────────────────────
# Deploy hook URL — called by the GitHub webhook handler to trigger a rebuild
VERCEL_DEPLOY_HOOK_URL=

# ── Docs repository ──────────────────────────────────────────────────────────
# The GitHub owner/repo that Project Pages reads content from
DOCS_REPO=vaimo/my-docs-repo

# Comma-separated branches to try (in order) when loading projectpages.config.
# Defaults to: master,main — no change needed for most repos.
CONFIG_BRANCH=master,main

# ── Chat (optional) ──────────────────────────────────────────────────────────
# Shared settings for the in-app chat tab. The per-branch backend URL itself
# lives in projectpages.config under `branches[].chat.backendUrl` — every
# branch points at its own LightRAG-compatible retrieval service.
#
# Each backend must speak the LightRAG HTTP API:
#   GET  <backendUrl>/health
#   POST <backendUrl>/query
#
# Optional bearer token sent as `Authorization: Bearer <key>` to every
# backend. (If different branches need different keys, this needs to move
# into per-branch config — file an issue.)
CHAT_API_KEY=

# Default query parameters forwarded to /query. Sensible defaults are used
# if these are omitted.
CHAT_QUERY_MODE=naive
CHAT_TOP_K=40
CHAT_CHUNK_TOP_K=25

# Prepended to every query as `user_prompt`. The default forces English
# answers (DeepSeek-style models otherwise drift to other languages).
CHAT_LANGUAGE_INSTRUCTION=You MUST respond in English.

# Timeout for chat backend calls, in milliseconds.
CHAT_TIMEOUT_MS=120000
