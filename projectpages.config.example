# projectpages.config.example
#
# This is the Project Pages configuration file — a reference showing all
# supported options with inline documentation.
#
# ── How to use this file ────────────────────────────────────────────────────
#
#   1. Copy this file to the ROOT of your knowledge-base repository.
#   2. Rename it to exactly:  projectpages.config   (no file extension)
#   3. The file only needs to exist in ONE branch of that repository
#      (the branch(es) listed in CONFIG_BRANCH — default: master, main).
#      Other content branches do not need a copy of this file.
#
# ── File location ───────────────────────────────────────────────────────────
#
#   <your-knowledge-base-repo>/
#   └── projectpages.config    ← place it here, in every relevant branch
#
# ── Format ──────────────────────────────────────────────────────────────────
#
#   YAML. Indentation matters. Use spaces, not tabs.
#
# ────────────────────────────────────────────────────────────────────────────

# ── Site identity ────────────────────────────────────────────────────────────
site:
  title: "My Project Docs"         # Required. Shown in browser tab and top nav.
  description: "Internal docs"     # Optional. Subtitle shown on the home page.

# ── Session settings ─────────────────────────────────────────────────────────
auth:
  sessionDurationDays: 7           # Optional. How long a login session lasts.
                                   # Default: 7. Set to 1 for short-lived access.

# ── User groups ──────────────────────────────────────────────────────────────
#
# Defines the audiences that can access this portal. Each group has a name
# and a passphrase. Users who enter the passphrase are authenticated as that
# group and can access whichever branches are assigned to it.
#
# Rules:
#   - At least one user group is required.
#   - Each passphrase must be unique across all groups.
#   - "passphrase" is stored in plain text here; treat this file like a secret.
#
userGroups:
  - name: vaimo                         # Internal team
    passphrase: "replace-with-secret"

  - name: client                        # Client audience
    passphrase: "replace-with-another-secret"

  # Add more groups as needed:
  # - name: external-partner
  #   passphrase: "partner-secret"

# ── Branches ─────────────────────────────────────────────────────────────────
#
# Each entry maps a Git branch to one or more user groups. Users land on the
# first branch in this list that their group can access. If their group has
# access to multiple branches, a branch switcher appears in the top nav.
#
# Rules:
#   - At least one branch is required.
#   - "name" must match an existing Git branch in the source repo.
#   - "userGroups" lists which groups can access this branch (by name).
#   - "comments.enabled" controls inline comments for this branch (default: false).
#   - "chat.backendUrl" enables the Chat tab on this branch and points it at
#     the LightRAG-compatible service indexed over this branch's content.
#     Each branch needs its own service indexed over its own corpus — LightRAG
#     cannot switch corpora per query. Omit this field to hide the Chat tab
#     when the user is on this branch.
#
branches:
  - name: master                        # Full internal content
    userGroups:
      - vaimo
      - client
    comments:
      enabled: false
    chat:
      backendUrl: "http://127.0.0.1:9621"   # LightRAG indexed over master

  - name: client                        # Curated client-facing content
    userGroups:
      - client
    comments:
      enabled: false
    # Omit chat.backendUrl to hide the Chat tab on this branch.

  # Add more branches as needed:
  # - name: external-partner
  #   userGroups:
  #     - external-partner
  #   comments:
  #     enabled: false
  #   chat:
  #     backendUrl: "http://127.0.0.1:9623"

# ── Chat ─────────────────────────────────────────────────────────────────────
#
# Opt-in conversational interface over the documentation. When enabled, a
# "Chat" tab appears in the top navigation alongside "Docs" — but only on
# branches whose entry above declares its own chat.backendUrl. Each branch
# talks to its own LightRAG-compatible retrieval service (one process per
# branch, each indexed over that branch's content).
#
# Shared chat configuration (api key, query mode, language instruction,
# timeout) lives in environment variables — see .env.local.example.
#
# Omit this block entirely to keep the chat tab hidden everywhere.
#
# chat:
#   enabled: true
#   title: "Ask the docs"                    # Optional. Shown above the chat.
#   welcome: "Ask anything about this..."    # Optional. First assistant message.
#   userGroups:                              # Optional. If omitted, every
#     - vaimo                                # group with branch access also
#     - client                               # gets chat access.
#   security:                                # Optional. Hardening knobs.
#     maxQueryChars: 4000                    #   Reject longer user messages.
#     maxHistoryTurns: 10                    #   Keep only the last N turns.
#     rateLimit:
#       perMinute: 30                        #   Cap messages per session/minute.
#       perHour: 300                         #   Cap messages per session/hour.

# ── Content filters ───────────────────────────────────────────────────────────
#
# "include" defines which files are visible. Supports full glob syntax.
# At least one pattern is required.
#
# "exclude" hides files that matched include. Optional.
#
include:
  - "**/*.md"
  - "**/*.csv"
  - "**/*.docx"
  - "**/*.vtt"
  - "**/*.srt"

exclude:                           # Optional.
  - "drafts/**"
  - "**/*.env"
  - ".github/**"
